NODE_ENV=production

# Channels (comma-separated: whatsapp,web). Default: web
CHANNELS=web

# Web server (used when 'web' channel is enabled)
WEB_PORT=3030
WEB_HOST=0.0.0.0

# Admin password for web UI (optional — leave empty for no auth)
ADMIN_PASSWORD=

# --- AI Provider Configuration ---
# Configure via Settings page (recommended) or env vars below.
# Settings page values override env vars.

# Generic defaults (apply to all providers unless overridden)
AI_API_BASE=
AI_DEFAULT_MODEL=

# Claude CLI (default provider — uses `claude login`, no API key needed)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Provider API keys (set here or in Settings page)
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DOUBAO_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=

# Per-provider overrides (optional)
# {PROVIDER}_API_BASE=     e.g. DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# {PROVIDER}_DEFAULT_MODEL= e.g. DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# Added by skill
ASSISTANT_HAS_OWN_NUMBER=
